    "jszip": "^3.10.1",
    "next": "16.2.10",
    "pdfjs-dist": "^6.1.200",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tesseract.js": "^5.1.1",
    "tesseract.js-core": "^5.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
