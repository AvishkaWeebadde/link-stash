{
  "manifest_version": 3,
  "name": "Save to LinkStash",
  "version": "1.0.0",
  "description": "Save the current page (or a link) to your local LinkStash library in one click.",
  "permissions": ["activeTab", "contextMenus", "notifications"],
  "host_permissions": ["http://127.0.0.1/*"],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "Save to LinkStash" },
  "icons": {
    "16": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": { "id": "linkstash@avishkaweebadde", "strict_min_version": "121.0" }
  }
}
