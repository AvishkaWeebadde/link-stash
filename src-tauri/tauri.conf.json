{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LinkStash",
  "version": "1.3.0",
  "identifier": "app.linkstash.desktop",
  "build": {
    "frontendDist": "../frontend",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev:local",
    "beforeBuildCommand": "node scripts/build-desktop.mjs"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI2MUM0MURFNjk3QUMwOUQKUldTZHdIcHAza0VjSnUrSjFDNGVkaG5DWGFYeFBZa1FSL2NoVGZ4N3Mxdi9seWI5akI2VUxoU3QK",
      "endpoints": [
        "https://github.com/AvishkaWeebadde/link-stash/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "resources": {
      "resources/server": "server",
      "resources/node.exe": "node.exe",
      "resources/linkstash-template.db": "linkstash-template.db"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
